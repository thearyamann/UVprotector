<?xml version="1.0" encoding="utf-8"?>
<!--
  Small Widget (2×2) — matched to uv_widget_premium_mockup_v2.html
  Changes from previous version:
    • padding: 16dp → 14dp  (HTML line 73: padding:14px)
    • UV number: 56sp → 52sp  (HTML line 76: font-size:52px)
    • Timer card padding: 12dp/10dp → 10dp/7dp  (HTML line 81: padding:7px 10px)
    • Timer font: 12sp → 11sp  (HTML line 83: font-size:11px)
    • Message card padding: 12dp/10dp → 9dp/7dp  (HTML line 91: padding:7px 9px)
    • Message line1: 10sp → 9sp  (HTML line 96: font-size:9px)
    • Message line2: 9sp → 8sp  (HTML line 97: font-size:8px)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/widget_glass_bg_small">

    <!-- Header Row: sun icon + "UV INDEX" label + risk pill -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_sun"
                android:alpha="0.48"/>

            <!-- "UV INDEX" 8sp bold tracking 1.2 rgba(255,255,255,0.30) — HTML line 184 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="UV INDEX"
                android:textColor="#36FFFFFF"
                android:textSize="8sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"/>
        </LinearLayout>

        <!-- Risk pill — HTML lines 63-70 -->
        <TextView
            android:id="@+id/sw_pill_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HIGH"
            android:textColor="#f97316"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:paddingStart="8dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/pill_bg_high"/>
    </LinearLayout>

    <!-- UV Number — HTML line 76: 52px bold tracking -3px -->
    <TextView
        android:id="@+id/sw_uv_number"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="6"
        android:textColor="#f97316"
        android:textSize="66sp"
        android:textStyle="bold"
        android:gravity="bottom"
        android:includeFontPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="6dp"/>

    <!-- Timer Card — HTML line 81: padding:7px 10px, border-radius:10px -->
    <LinearLayout
        android:id="@+id/sw_timer_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@drawable/inner_card_small_bg">

        <!-- Shield/star icon — HTML: 12×12 shield star SVG -->
        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_shield"
            android:alpha="0.55"/>

        <!-- Timer text — HTML line 83: 11px weight 600 monospace rgba(255,255,255,0.85) -->
        <Chronometer
            android:id="@+id/sw_timer_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="01:22"
            android:textColor="#D9FFFFFF"
            android:textSize="11.5sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>

        <!-- Sub label — HTML line 84: 9px rgba(255,255,255,0.38) -->
        <TextView
            android:id="@+id/sw_timer_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active"
            android:textColor="#61FFFFFF"
            android:textSize="9sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sw_prompt_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="11dp"
        android:paddingEnd="11dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@drawable/inner_card_small_bg">

        <TextView
            android:id="@+id/sw_prompt_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apply sunscreen"
            android:textColor="#fbbf24"
            android:textSize="8.5sp"
            android:textStyle="bold"
            android:maxLines="1"/>

        <TextView
            android:id="@+id/sw_prompt_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Protect skin before going out"
            android:textColor="#8AFFFFFF"
            android:textSize="7.5sp"
            android:maxLines="2"/>
    </LinearLayout>

    <!-- Low UV Message Card — HTML lines 87-97: green tint, 7px 9px padding -->
    <LinearLayout
        android:id="@+id/sw_message_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="11dp"
        android:paddingEnd="11dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@drawable/inner_card_green_small_bg">

        <!-- Line 1 — HTML line 96: 9px weight 600 #4ade80 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No cream needed"
            android:textColor="#4ade80"
            android:textSize="8.5sp"
            android:textStyle="bold"/>

        <!-- Line 2 — HTML line 97: 8px rgba(255,255,255,0.38) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Check when heading outside"
            android:textColor="#8AFFFFFF"
            android:textSize="7.5sp"/>
    </LinearLayout>

</LinearLayout>
