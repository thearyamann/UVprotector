<?xml version="1.0" encoding="utf-8"?>
<!--
  Medium Widget (4×2) — matched to uv_widget_premium_mockup_v2.html
  Changes from previous version:
    • outer padding: 16dp → 14dp vertical, 16dp horizontal  (HTML: padding:14px 16px)
    • left column gap: 16dp → 14dp  (HTML: gap:14px)
    • left column width: 95dp → 110dp  (HTML: width:110px)
    • ring container: 76dp → 72dp  (HTML: 72×72px)
    • UV number in ring: 28sp → 26sp  (HTML: 26px)
    • active panel padding: 12dp all → 10dp vertical 12dp horizontal  (HTML: padding:10px 12px)
    • sessions bar height: 4dp → 3dp  (HTML: height:3px)
    • sessions bar margin-bottom: 6dp → 5dp  (HTML: gap:5px)
    • low panel message line1: 13sp → 12sp  (HTML: 12px)
    • low panel padding: 12dp → 11dp vertical 13dp horizontal  (HTML: padding:11px 13px)
    • low UV sub text color: #8CFFFFFF → #6BFFFFFF  (HTML: rgba(255,255,255,0.42))
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:background="@drawable/widget_glass_bg_transparent">

    <!-- LEFT COLUMN — HTML mw-left: width:110px, flex-column, space-between -->
    <LinearLayout
        android:layout_width="110dp"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- "UV INDEX" label — HTML line 102: 9px bold tracking 1.5 rgba(255,255,255,0.32) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UV INDEX"
            android:textColor="#52FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"/>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <!-- Ring + UV number — HTML mw-ring-wrap: 72×72, r=28 -->
        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp">

            <ImageView
                android:id="@+id/mw_ring"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <!-- UV number centered — HTML mw-index: 26px bold risk-color -->
            <TextView
                android:id="@+id/mw_uv_number"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="6"
                android:textColor="#f97316"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"/>
        </FrameLayout>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <!-- Burn time row — HTML lines 110-114: flame + "Burn in " muted + value risk-colored -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/ic_flame"
                android:alpha="0.55"/>

            <!-- "Burn in X mins" — value is risk-colored, full string set in Kotlin -->
            <TextView
                android:id="@+id/mw_burn_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="Burn in 11 mins"
                android:textColor="#f97316"
                android:textSize="10sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Gap: 14dp — HTML: gap:14px -->
    <View android:layout_width="14dp" android:layout_height="0dp"/>

    <!-- RIGHT PANEL CONTAINER -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <!-- ACTIVE PANEL — HTML mw-right: padding:10px 12px, bg rgba(255,255,255,0.06) -->
        <LinearLayout
            android:id="@+id/mw_active_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:background="@drawable/inner_card_bg">

            <!-- Protection status pill — HTML mw-protect-pill: 9px bold tracking 0.6 -->
            <TextView
                android:id="@+id/mw_protect_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PROTECTED"
                android:textColor="#4ade80"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:paddingStart="7dp"
                android:paddingEnd="9dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/pill_bg_green"/>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            <!-- Countdown timer — HTML mw-timer: 28px weight 500 monospace tracking -1px -->
            <TextView
                android:id="@+id/mw_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01:22:45"
                android:textColor="#EBFFFFFF"
                android:textSize="28sp"
                android:fontFamily="monospace"/>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            <!-- Sessions section — HTML mw-sessions-bar: gap:5px -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Label — HTML mw-sessions-label: 9px rgba(255,255,255,0.35) -->
                <TextView
                    android:id="@+id/mw_sessions_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 / 3 Sessions"
                    android:textColor="#59FFFFFF"
                    android:textSize="9sp"
                    android:layout_marginBottom="5dp"/>

                <!-- Bar — HTML sessions-track: height:3px -->
                <ImageView
                    android:id="@+id/mw_sessions_bar"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:scaleType="fitXY"/>
            </LinearLayout>
        </LinearLayout>

        <!-- LOW UV PANEL — HTML mw-right-low: padding:11px 13px, green tint -->
        <LinearLayout
            android:id="@+id/mw_low_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="13dp"
            android:paddingEnd="13dp"
            android:paddingTop="11dp"
            android:paddingBottom="11dp"
            android:background="@drawable/inner_card_green_bg"
            android:visibility="gone">

            <!-- "UV IS LOW" pill — green -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UV IS LOW"
                android:textColor="#4ade80"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:paddingStart="7dp"
                android:paddingEnd="9dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/pill_bg_green"/>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            <!-- Message block — HTML mw-no-cream-title/sub, gap:3px -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Line 1 — HTML mw-no-cream-title: 12px bold #4ade80 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No cream needed at the moment"
                    android:textColor="#4ade80"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <!-- Line 2 — HTML mw-no-cream-sub: 10px rgba(255,255,255,0.42) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Check again when you head outside"
                    android:textColor="#6BFFFFFF"
                    android:textSize="10sp"/>
            </LinearLayout>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            <!-- Sessions muted — HTML: rgba(255,255,255,0.25) -->
            <TextView
                android:id="@+id/mw_low_sessions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 3 Sessions"
                android:textColor="#40FFFFFF"
                android:textSize="9sp"/>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>