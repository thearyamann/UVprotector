<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@drawable/widget_glass_bg_medium">

    <LinearLayout
        android:layout_width="108dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingStart="10dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_sun"
                android:alpha="0.48"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="UV INDEX"
                android:textColor="#36FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"/>
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="" />

        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp">

            <ImageView
                android:id="@+id/mw_ring"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <TextView
                android:id="@+id/mw_uv_number"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="6"
                android:textColor="#f9741b"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"/>
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:src="@drawable/ic_flame"
                android:alpha="0.55"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="Burn in:"
                android:textColor="#8AFFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/mw_burn_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="11 mins"
                android:textColor="#f9741b"
                android:textSize="10sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="10dp"
        android:layout_height="0dp"
        android:text="" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/mw_active_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/inner_card_bg">

            <TextView
                android:id="@+id/mw_protect_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PROTECTED"
                android:textColor="#4ade80"
                android:textSize="8sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:paddingStart="7dp"
                android:paddingEnd="9dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/pill_bg_green"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="" />

            <LinearLayout
                android:id="@+id/mw_timer_block"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Chronometer
                    android:id="@+id/mw_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01:22:45"
                    android:textColor="#EBFFFFFF"
                    android:textSize="28sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/mw_prompt_block"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/mw_prompt_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready for the sun?"
                    android:textColor="#F0FFFFFF"
                    android:textSize="14.5sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/mw_prompt_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Apply sunscreen for protection"
                    android:textColor="#8AFFFFFF"
                    android:textSize="8.8sp" />
            </LinearLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="" />

            <TextView
                android:id="@+id/mw_sessions_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 / 3 Sessions"
                android:textColor="#59FFFFFF"
                android:textSize="8sp"
                android:layout_marginBottom="4dp"/>

            <ImageView
                android:id="@+id/mw_sessions_bar"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:scaleType="fitXY"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/mw_low_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/inner_card_green_bg"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UV IS LOW"
                android:textColor="#4ade80"
                android:textSize="8sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:paddingStart="7dp"
                android:paddingEnd="9dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/pill_bg_green"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No cream needed at the moment"
                    android:textColor="#4ade80"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Check again when you head outside"
                    android:textColor="#6BFFFFFF"
                    android:textSize="10sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="" />

            <TextView
                android:id="@+id/mw_low_sessions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 3 Sessions"
                android:textColor="#40FFFFFF"
                android:textSize="8sp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
