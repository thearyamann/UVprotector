<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_glass_bg"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:orientation="horizontal"
    android:baselineAligned="false">

    <!-- Left Column (Static Structure) -->
    <LinearLayout
        android:layout_width="110dp"
        android:layout_height="match_parent"
        android:orientation="vertical">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UV INDEX"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#52FFFFFF" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Circular Ring filled by Kotlin Canvas -->
        <ImageView
            android:id="@+id/iv_uv_ring"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@android:drawable/ic_dialog_alert"
                android:tint="#8CFFFFFF"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Burn in "
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#8CFFFFFF"
                android:layout_marginStart="4dp"/>
            <TextView
                android:id="@+id/tv_burn_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="11 mins"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#f97316"/>
        </LinearLayout>
    </LinearLayout>
    
    <Space
        android:layout_width="14dp"
        android:layout_height="match_parent" />

    <!-- Right Column Container -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">
        
        <!-- Standard Right Card -->
        <RelativeLayout
            android:id="@+id/right_card_standard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/widget_inner_glass"
            android:padding="12dp">
            
            <ImageView
                android:id="@+id/iv_protection_pill"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:adjustViewBounds="true"
                android:layout_alignParentTop="true"
                android:layout_alignParentStart="true"/>

            <Chronometer
                android:id="@+id/timer_large"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:textColor="#EBEBEB"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="monospace"/>
                
            <TextView
                android:id="@+id/tv_timer_large_fallback"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:textColor="#4DFFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:text="--:--:--"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_sessions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 / 3 Sessions"
                    android:textSize="9sp"
                    android:textColor="#80FFFFFF"
                    android:layout_marginBottom="4dp"/>
                
                <ImageView
                    android:id="@+id/iv_session_progress"
                    android:layout_width="match_parent"
                    android:layout_height="3dp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Low UV Right Card -->
        <RelativeLayout
            android:id="@+id/right_card_low_uv"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/widget_inner_glass_low_uv_medium"
            android:padding="12dp"
            android:visibility="gone">
            
            <ImageView
                android:id="@+id/iv_low_uv_pill"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:adjustViewBounds="true"
                android:layout_alignParentTop="true"
                android:layout_alignParentStart="true"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No cream needed at the moment"
                    android:textColor="#4ade80"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Check again when you head outside"
                    android:textColor="#6bFFFFFF"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_sessions_low_uv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:text="0 / 3 Sessions"
                android:textSize="9sp"
                android:textColor="#40FFFFFF"/>
        </RelativeLayout>
    </FrameLayout>
</LinearLayout>
